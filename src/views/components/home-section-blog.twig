{% if theme.settings.get('show_blog_section')|default(true) %}
  <section class="mx-auto w-full max-w-[1400px] px-4 py-8">
    <div class="mb-4 flex items-center justify-between">
      <h2 class="text-2xl font-bold text-[#01012D]">{{ salla.lang.get('sections.blog') }}</h2>
      <a href="/blog" class="text-sm font-semibold text-sky-700 hover:text-sky-900">{{ salla.lang.get('common.view_all') }}</a>
    </div>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
      {% for post in blog_posts|default([])|slice(0, 3) %}
        <article class="rounded-xl border border-slate-200 bg-white p-4 shadow-soft">
          <h3 class="line-clamp-2 text-base font-semibold text-[#01012D]">{{ post.title }}</h3>
          <p class="mt-2 line-clamp-3 text-sm text-slate-600">{{ post.excerpt|default('') }}</p>
          <a href="{{ post.url|default('/blog') }}" class="mt-3 inline-flex text-sm font-semibold text-sky-700 hover:text-sky-900">{{ salla.lang.get('common.read_more') }}</a>
        </article>
      {% else %}
        <p class="text-sm text-slate-500">{{ salla.lang.get('sections.blog_empty') }}</p>
      {% endfor %}
    </div>
  </section>
{% endif %}
