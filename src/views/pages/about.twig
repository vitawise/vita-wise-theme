{% extends 'layouts/master.twig' %}

{% block title %}{{ salla.lang.get('nav.about') }} - {{ store.name }}{% endblock %}
{% block description %}{{ theme.settings.get('about_description')|default(salla.lang.get('about.description')) }}{% endblock %}

{% block content %}
  <section class="mx-auto w-full max-w-[1200px] px-4 py-10">
    {%- include 'partials/page-header.twig' with {
      title: theme.settings.get('about_title')|default(salla.lang.get('about.title')),
      subtitle: theme.settings.get('about_description')|default(salla.lang.get('about.description'))
    } -%}

    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <article class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="mb-2 text-base font-semibold text-[#01012D]">{{ salla.lang.get('about.feature_1_title') }}</h3>
        <p class="text-sm text-slate-600">{{ salla.lang.get('about.feature_1_text') }}</p>
      </article>
      <article class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="mb-2 text-base font-semibold text-[#01012D]">{{ salla.lang.get('about.feature_2_title') }}</h3>
        <p class="text-sm text-slate-600">{{ salla.lang.get('about.feature_2_text') }}</p>
      </article>
      <article class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="mb-2 text-base font-semibold text-[#01012D]">{{ salla.lang.get('about.feature_3_title') }}</h3>
        <p class="text-sm text-slate-600">{{ salla.lang.get('about.feature_3_text') }}</p>
      </article>
      <article class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="mb-2 text-base font-semibold text-[#01012D]">{{ salla.lang.get('about.feature_4_title') }}</h3>
        <p class="text-sm text-slate-600">{{ salla.lang.get('about.feature_4_text') }}</p>
      </article>
    </div>
  </section>
{% endblock %}
