{% extends 'layouts/master.twig' %}

{% block title %}{{ salla.lang.get('pages.cart') }} - {{ store.name }}{% endblock %}

{% block content %}
  <section class="mx-auto w-full max-w-[1400px] px-4 py-8">
    <h1 class="mb-6 text-3xl font-bold text-[#01012D]">{{ salla.lang.get('pages.cart') }}</h1>
    <div class="grid gap-6 lg:grid-cols-[2fr_1fr]">
      <div class="rounded-2xl border border-slate-200 bg-white p-4">
        <salla-cart></salla-cart>
      </div>
      <aside class="h-fit rounded-2xl border border-slate-200 bg-white p-4 lg:sticky lg:top-24">
        <h2 class="mb-4 text-xl font-semibold">{{ salla.lang.get('cart.summary') }}</h2>
        <ul class="space-y-2 text-sm text-slate-700">
          <li class="flex justify-between"><span>{{ salla.lang.get('cart.subtotal') }}</span><span>{{ cart.subtotal|money|default('--') }}</span></li>
          <li class="flex justify-between"><span>{{ salla.lang.get('cart.vat') }}</span><span>{{ cart.tax|money|default('--') }}</span></li>
          <li class="flex justify-between"><span>{{ salla.lang.get('cart.shipping') }}</span><span>{{ cart.shipping|money|default('--') }}</span></li>
        </ul>
        <p class="mt-3 text-xs text-slate-500">{{ salla.lang.get('cart.free_shipping_hint') }}</p>
        <hr class="my-4">
        <div class="mb-4 flex justify-between text-lg font-bold">
          <span>{{ salla.lang.get('cart.total') }}</span>
          <span>{{ cart.total|money|default('--') }}</span>
        </div>
        <a href="/checkout" class="inline-flex w-full justify-center rounded-lg bg-sky-600 px-4 py-3 font-semibold text-white hover:bg-sky-700">
          {{ salla.lang.get('cart.proceed_checkout') }}
        </a>
      </aside>
    </div>
  </section>
{% endblock %}
