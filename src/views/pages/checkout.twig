{% extends 'layouts/master.twig' %}

{% block title %}{{ salla.lang.get('pages.checkout') }} - {{ store.name }}{% endblock %}

{% block content %}
  <section class="mx-auto w-full max-w-[1400px] px-4 py-8">
    <h1 class="mb-6 text-3xl font-bold text-[#01012D]">{{ salla.lang.get('pages.checkout') }}</h1>
    <div class="grid gap-6 lg:grid-cols-[2fr_1fr]">
      <form class="space-y-6 rounded-2xl border border-slate-200 bg-white p-6" data-checkout-form novalidate>
        <div data-checkout-errors class="hidden rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700"></div>
        <div>
          <h2 class="mb-3 text-lg font-semibold">{{ salla.lang.get('checkout.customer_info') }}</h2>
          <div class="grid gap-3 sm:grid-cols-2">
            <input name="customer_name" required minlength="2" class="rounded-lg border border-slate-300 px-3 py-2" placeholder="{{ salla.lang.get('checkout.name') }}">
            <input name="customer_email" type="email" required class="rounded-lg border border-slate-300 px-3 py-2" placeholder="{{ salla.lang.get('checkout.email') }}">
            <input name="customer_phone" class="rounded-lg border border-slate-300 px-3 py-2 sm:col-span-2" placeholder="{{ salla.lang.get('checkout.phone') }}">
          </div>
        </div>

        <div>
          <h2 class="mb-3 text-lg font-semibold">{{ salla.lang.get('checkout.shipping_address') }}</h2>
          <div class="grid gap-3 sm:grid-cols-2">
            <input name="street" required minlength="5" class="rounded-lg border border-slate-300 px-3 py-2 sm:col-span-2" placeholder="{{ salla.lang.get('checkout.street') }}">
            <input name="city" required minlength="2" class="rounded-lg border border-slate-300 px-3 py-2" placeholder="{{ salla.lang.get('checkout.city') }}">
            <input name="postal_code" required minlength="3" class="rounded-lg border border-slate-300 px-3 py-2" placeholder="{{ salla.lang.get('checkout.postal_code') }}">
            <input name="country" required minlength="2" value="Saudi Arabia" class="rounded-lg border border-slate-300 px-3 py-2 sm:col-span-2" placeholder="{{ salla.lang.get('checkout.country') }}">
          </div>
        </div>

        <div>
          <h2 class="mb-3 text-lg font-semibold">{{ salla.lang.get('checkout.payment_method') }}</h2>
          <div class="grid gap-2 sm:grid-cols-2">
            <label class="flex items-center gap-2 rounded-lg border border-slate-300 p-3"><input type="radio" name="payment" value="cod" checked> {{ salla.lang.get('checkout.cod') }}</label>
            <label class="flex items-center gap-2 rounded-lg border border-slate-300 p-3"><input type="radio" name="payment" value="card"> {{ salla.lang.get('checkout.card') }}</label>
            <label class="flex items-center gap-2 rounded-lg border border-slate-300 p-3"><input type="radio" name="payment" value="stc"> {{ salla.lang.get('checkout.stc') }}</label>
            <label class="flex items-center gap-2 rounded-lg border border-slate-300 p-3"><input type="radio" name="payment" value="bank"> {{ salla.lang.get('checkout.bank') }}</label>
          </div>
        </div>

        <div data-card-fields class="hidden">
          <h2 class="mb-3 text-lg font-semibold">{{ salla.lang.get('checkout.card_details') }}</h2>
          <div class="grid gap-3 sm:grid-cols-2">
            <input name="card_name" class="rounded-lg border border-slate-300 px-3 py-2 sm:col-span-2" placeholder="{{ salla.lang.get('checkout.card_name') }}">
            <input name="card_number" inputmode="numeric" class="rounded-lg border border-slate-300 px-3 py-2 sm:col-span-2" placeholder="{{ salla.lang.get('checkout.card_number') }}">
            <input name="card_expiry" class="rounded-lg border border-slate-300 px-3 py-2" placeholder="{{ salla.lang.get('checkout.card_expiry') }}">
            <input name="card_cvv" inputmode="numeric" class="rounded-lg border border-slate-300 px-3 py-2" placeholder="{{ salla.lang.get('checkout.card_cvv') }}">
          </div>
        </div>

        <div>
          <h2 class="mb-3 text-lg font-semibold">{{ salla.lang.get('checkout.discount_code') }}</h2>
          <div class="flex gap-2">
            <input name="discount_code" class="w-full rounded-lg border border-slate-300 px-3 py-2" placeholder="{{ salla.lang.get('checkout.discount_placeholder') }}">
            <button type="button" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold">{{ salla.lang.get('checkout.apply') }}</button>
          </div>
        </div>

        <div>
          <h2 class="mb-3 text-lg font-semibold">{{ salla.lang.get('checkout.notes') }}</h2>
          <textarea name="notes" rows="4" class="w-full rounded-lg border border-slate-300 px-3 py-2" placeholder="{{ salla.lang.get('checkout.notes_placeholder') }}"></textarea>
        </div>

        <button type="submit" class="inline-flex rounded-lg bg-sky-600 px-6 py-3 font-semibold text-white hover:bg-sky-700">
          {{ salla.lang.get('checkout.place_order') }}
        </button>
      </form>

      <aside class="h-fit rounded-2xl border border-slate-200 bg-white p-6 lg:sticky lg:top-24">
        <h2 class="mb-4 text-xl font-semibold">{{ salla.lang.get('cart.summary') }}</h2>
        <div class="space-y-2 text-sm text-slate-700">
          <div class="flex justify-between"><span>{{ salla.lang.get('cart.subtotal') }}</span><span>{{ cart.subtotal|money|default('--') }}</span></div>
          <div class="flex justify-between"><span>{{ salla.lang.get('cart.vat') }}</span><span>{{ cart.tax|money|default('--') }}</span></div>
          <div class="flex justify-between"><span>{{ salla.lang.get('cart.shipping') }}</span><span>{{ cart.shipping|money|default('--') }}</span></div>
        </div>
        <hr class="my-4">
        <div class="flex justify-between text-lg font-bold">
          <span>{{ salla.lang.get('cart.total') }}</span>
          <span>{{ cart.total|money|default('--') }}</span>
        </div>
      </aside>
    </div>
  </section>
{% endblock %}
