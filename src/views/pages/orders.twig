{% extends 'layouts/master.twig' %}

{% block title %}{{ salla.lang.get('pages.orders') }} - {{ store.name }}{% endblock %}

{% block content %}
  <section class="mx-auto w-full max-w-[1400px] px-4 py-8">
    <h1 class="mb-6 text-3xl font-bold text-[#01012D]">{{ salla.lang.get('pages.orders') }}</h1>
    <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white">
      <table class="min-w-full text-sm">
        <thead class="bg-slate-50 text-slate-600">
          <tr>
            <th class="px-4 py-3 text-start">{{ salla.lang.get('orders.number') }}</th>
            <th class="px-4 py-3 text-start">{{ salla.lang.get('orders.date') }}</th>
            <th class="px-4 py-3 text-start">{{ salla.lang.get('orders.status') }}</th>
            <th class="px-4 py-3 text-start">{{ salla.lang.get('orders.total') }}</th>
          </tr>
        </thead>
        <tbody>
          {% for order in orders|default([]) %}
            <tr class="border-t border-slate-100">
              <td class="px-4 py-3">{{ order.reference_id|default(order.id) }}</td>
              <td class="px-4 py-3">{{ order.date|date('Y-m-d') }}</td>
              <td class="px-4 py-3">
                {% set order_status = order.status|default(salla.lang.get('orders.pending')) %}
                <span class="rounded-full px-2 py-1 text-xs font-semibold
                  {{ order_status in ['delivered', 'completed'] ? 'bg-emerald-100 text-emerald-700' : '' }}
                  {{ order_status in ['shipped', 'processing'] ? 'bg-sky-100 text-sky-700' : '' }}
                  {{ order_status in ['pending'] ? 'bg-amber-100 text-amber-700' : '' }}
                  {{ order_status in ['cancelled', 'failed'] ? 'bg-red-100 text-red-700' : '' }}
                ">{{ order_status }}</span>
              </td>
              <td class="px-4 py-3">{{ order.total|money }}</td>
            </tr>
          {% else %}
            <tr>
              <td colspan="4" class="px-4 py-8 text-center text-slate-500">{{ salla.lang.get('orders.empty') }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
{% endblock %}
