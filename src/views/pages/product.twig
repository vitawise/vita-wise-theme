{% extends 'layouts/master.twig' %}

{% block title %}{{ product.name|default(salla.lang.get('pages.product')) }} - {{ store.name }}{% endblock %}
{% block description %}{{ product.description|striptags|default(salla.lang.get('meta.product_description')) }}{% endblock %}

{% block content %}
  <section class="mx-auto w-full max-w-[1400px] px-4 py-8">
    <nav class="mb-5 text-sm text-slate-500">
      <a href="/" class="hover:text-slate-700">{{ salla.lang.get('nav.home') }}</a>
      <span class="mx-1">/</span>
      <a href="/products" class="hover:text-slate-700">{{ salla.lang.get('nav.products') }}</a>
      <span class="mx-1">/</span>
      <span>{{ product.name }}</span>
    </nav>

    <div class="grid gap-8 lg:grid-cols-2">
      <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white">
        <img src="{{ product.image.url|default(product.image) }}" alt="{{ product.name }}" class="aspect-square w-full object-cover" />
      </div>

      <div class="space-y-5">
        <h1 class="text-3xl font-bold text-[#01012D]">{{ product.name }}</h1>
        <div class="flex items-center gap-3">
          <salla-rating value="{{ product.rating|default(4.6) }}"></salla-rating>
          <span class="text-sm text-slate-500">({{ product.rating_count|default(0) }} {{ salla.lang.get('common.reviews') }})</span>
        </div>

        <div class="flex items-center gap-3">
          <span class="text-3xl font-bold text-sky-700">{{ product.sale_price|money|default(product.price|money) }}</span>
          {% if product.regular_price and product.regular_price > product.sale_price %}
            <span class="text-lg text-slate-400 line-through">{{ product.regular_price|money }}</span>
          {% endif %}
        </div>

        <div class="prose max-w-none text-slate-700">{{ product.description|raw }}</div>

        <div class="flex items-center gap-3">
          <label class="text-sm font-medium text-slate-700">{{ salla.lang.get('product.quantity') }}</label>
          <input type="number" min="1" value="1" class="w-20 rounded-lg border border-slate-300 px-2 py-1" data-product-qty>
          {% if product.quantity and product.quantity < 1 %}
            <span class="rounded-full bg-red-100 px-3 py-1 text-xs font-semibold text-red-700">{{ salla.lang.get('product.out_of_stock') }}</span>
          {% else %}
            <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700">{{ salla.lang.get('product.in_stock') }}</span>
          {% endif %}
        </div>

        <div class="flex flex-wrap gap-3">
          <button class="rounded-lg bg-sky-600 px-6 py-3 text-sm font-semibold text-white hover:bg-sky-700" data-add-to-cart data-product-id="{{ product.id }}">
            {{ salla.lang.get('common.add_to_cart') }}
          </button>
          <salla-wishlist-button product-id="{{ product.id }}"></salla-wishlist-button>
        </div>
      </div>
    </div>

    <section class="mt-10">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-2xl font-bold text-[#01012D]">{{ salla.lang.get('product.related') }}</h2>
        <a href="/products" class="text-sm font-semibold text-sky-700 hover:text-sky-900">{{ salla.lang.get('common.view_all') }}</a>
      </div>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {% for item in related_products|default([])|slice(0, 4) %}
          {%- include 'components/product-card.twig' with { product: item } -%}
        {% else %}
          <p class="text-sm text-slate-500">{{ salla.lang.get('common.no_products') }}</p>
        {% endfor %}
      </div>
    </section>
  </section>
{% endblock %}
